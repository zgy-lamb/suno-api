# For more information, please see the README.md
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true
# Optional — 2Captcha Click/Coordinates price per 1000 solves (default 1.2)
TWOCAPTCHA_PRICE_PER_1000=1.2
# Optional — where to persist captcha spend stats (default ./data/captcha-stats.json)
CAPTCHA_STATS_FILE=